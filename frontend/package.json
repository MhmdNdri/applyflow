{
  "name": "applyflow-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.4",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
